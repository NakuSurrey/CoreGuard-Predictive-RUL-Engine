# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
.env

# Data files (too large for GitHub, users download separately)
data/raw/*.txt
data/raw/*.zip
data/raw/*.pdf
data/processed/*.csv

# Trained model files (too large for GitHub, regenerated by training script)
models/*.pkl
models/*.h5
models/*.joblib

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# IDE settings
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Local-only documentation (kept in docs/ folder, not pushed to GitHub)
# README.md in root is NOT affected — it stays on GitHub
docs/*.md
docs/adr/*.md
CLAUDE.md
PLAN.md
ERRORS.md
PHASE_*_REFERENCE.md

# Distribution / packaging
dist/
build/
*.egg-info/
